# TokenUsage does not require any environment variables to run.
# The variables below are only needed to build and notarize a signed macOS distributable.
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# macOS code signing — Apple Developer ID Application certificate name
# Example: "Developer ID Application: Jane Smith (TEAM1234567)"
CSC_LINK=
CSC_KEY_PASSWORD=

# macOS notarization — App Store Connect API key
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
